NEXT_PUBLIC_APP_NAME=Fiche pédagogique
NEXT_PUBLIC_APP_URL=http://localhost:3000

IMPORT_SECRET_KEY=CLE_SECURISEE
AUTH_SECRET=changez-cette-valeur-en-production
DATABASE_URL=postgresql://postgres:mot-de-passe@host:5432/postgres?sslmode=require
# L'application accepte aussi POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING,
# SUPABASE_DB_URL ou SUPABASE_POSTGRES_URL si Vercel/Supabase les fournit.

# Optionnel : seulement si vous voulez une mise en forme automatique par Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite